#include <stdio.h>
#include <math.h>
float power(float n,float x);

 int main(){
     float f= power(2,4);
     printf("%f",f);
     return 0;
    
 }
  float power(float n,float x){
      if(x==0){
          return 1;
      }
      if(n==0){
          return 0;
      }
      if(n==1){
          return 1;
      }
      float p=n*pow(n,x-1);
      return p;
}
